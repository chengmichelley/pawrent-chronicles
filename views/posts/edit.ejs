<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css">
    <title>Edit Post <%= post.title %></title>
  </head>
  <body>
    <h1>Edit Post <%= post.title %></h1>
    <form
      action="/users/<%=blogOwner._id %>/posts/<%= post._id %>?_method=PUT"
      method="POST"
    >
      <label for="title">Title:</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= post.title %>"
        required
      />

      <label for="content">Content: </label>
      <textarea
        name="content"
        id="content"
        placeholder="Enter details about Post"
      ><%= post.content %></textarea>

      <label for="deletedAt">Deleted</label>
      <input 
        type="checkbox" 
        id="deletedAt" 
        name="deletedAt" 
        <%= post.deletedAt ? 'checked' : '' %>
      />

      <button type="submit">Update Post!</button>
      <a href="/users/<%= blogOwner._id %>/posts/<%= post._id %>">Cancel & Go Back</a>
    </form>
  </body>
</html>
