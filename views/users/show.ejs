<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="stylesheet" href="/css/style.css" />
        <title>Pawrent Chronicles | <%= blogOwner.username %>'s Profile</title>
    </head>
    <body>
        <%- include('../partials/_navbar.ejs') %>
        <div class="profile">
			<% if(blogOwner.photo) { %>
				<img src="<%= blogOwner.photo %>" alt="<%= blogOwner.username %>">
			<% } else { %>
				<div class="profile-placeholder">👤</div>

			<% } %>
            <h1>Username: <em><%= blogOwner.username %></em></h1>
            <p>
                <strong>Member Since:</strong> <%= new
                Date(blogOwner.createdAt).toLocaleDateString() %>
            </p>
            <hr />
            <h2>Meet My Pack!</h2>
            <% if (blogOwner.pets && blogOwner.pets.length > 0) { %>
            <ul>
                <% blogOwner.pets.forEach((pet)=> {%>
                <li>
                    <%= pet.name %>'s a <%= pet.breed %> <%= pet.species %>. <%=
                    pet.gender %> is <%= pet.age %> years old! <% if (pet.photo)
                    { %>
                    <img src="<%= pet.photo %>" alt="<%= pet.name %>" class="pet-edit-photo" />
                    <% } else { %>
                    <img
                        src="/images/HappyDogAndCat.jpg"
                        alt="Happy Dog and Cat"/>
						class="pet-edit-photo"
                    <% } %> <% if (locals.user &&
                    blogOwner._id.equals(locals.user._id)) { %>
                    <a href="/users/<%= blogOwner._id %>/pets/<%= pet._id %>/edit">Edit Pet</a>
                    <form action="/users/<%= blogOwner._id %>/pets/<%= pet._id %>?_method=DELETE" method="POST">
                        <button type="submit" class="delete-btn">Remove</button>
                    </form>
                    <% } %>
                </li>
                <% }) %>
            </ul>
            <% } %> <% if (locals.user && blogOwner._id.equals(locals.user._id))
            { %>
            <hr />
            <h3>Add a New Fur Baby!</h3>
            <form action="/users/<%= blogOwner._id %>/pets" method="POST" enctype="multipart/form-data">
                <div class="form-container">
                    <div class="file-upload-container">
                        <input type="file" name="photo" id="pet-photo-input" accept="image/*" hidden/>
                        <label for="pet-photo-input" class="custom-file-upload">Choose Your Fur Baby's Photo!</label>
						<span class="file-requirement">Files must be under 100MB</span>
                        <span id="pet-file-status">Pick a good photo!</span>
                    </div>
                    <input type="text" name="name" id="name" placeholder="Fur Baby Name" required/>
                    <select type="gender" name="gender" id="gender" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option value="He">He</option>
                        <option value="She">She</option>
                    </select>
                    <select type="species" name="species" id="species" required>
                        <option value="" disabled selected>Species</option>
                        <option value="Dog">Dog</option>
                        <option value="Cat">Cat</option>
                    </select>
                    <input type="text"name="breed" id="breed" placeholder="Breed" required/>
                    <input type="number" name="age" id="age" placeholder="Age" min="0" max="35" required/>
                    <button type="submit">Add To My Pack!</button>
                </div>
            </form>
            <% } %>
            <a href="/users/<%= blogOwner._id %>/posts">View My Pet Chronicles</a>
            <% if (locals.user && blogOwner._id.equals(locals.user._id)) { %>
            <p>
                <a href="/users/<%= blogOwner._id %>/edit" class="edit-btn">Edit My Profile</a>
            </p>
            <% } %>
            <p>Chronicles Shared:<%= blogOwner.posts.length %></p>

            <script>
    			const fileInput = document.getElementById('pet-photo-input');
    			const statusText = document.querySelector('.file-requirement + span');
   				const ageInput = document.getElementById('age');
				const petForm = document.querySelector('form[action$="/pets"]');

    			ageInput.addEventListener('input', function() {
        
				const age = parseInt(this.value);
        			if(age < 0) {
            			this.value = 0;
           				 alert('Fur baby cannot have a negative age!');
        			} else if (age > 35) {
            			this.value = 35;
            			alert("Are you sure your fur baby is over 35?");
        	}
    	});

    	fileInput.addEventListener('change', function() {
        	if(this.files && this.files.length > 0) {
            const fileSize = this.files[0].size / 1024 / 1024; 
            
            if (fileSize > 100) {
                alert("This file is too large! Please choose a photo under 100MB.");
                this.value = ""; 
                statusText.textContent = "File too large (Max 100MB)";
                statusText.style.color = "#e74c3c";
            } else {
                statusText.textContent = "Selected: " + this.files[0].name;
                statusText.style.color = "#2ecc71";
            }
        }
    });

	if (petForm) {
		petForm.addEventListener('submit', function() {
			const btn = this.querySelector('button[type="submit"]');

			btn.textContent = "Uploading... please wait";
			btn.style.opacity = ".7";
			btn.disabled = true;
		});
	}
</script>

        </div>
    </body>
</html>
