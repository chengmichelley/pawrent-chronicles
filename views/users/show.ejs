<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%=user.username %> Pantry
    </title>
</head>

<body>
    <%- include('../partials/_navbar.ejs') %>
        <h1>Welcome to <%= user.username %> Pantry</h1>
            <% if (typeof pantry !=='undefined' && pantry.length> 0) { %>
                <ul>
                    <% pantry.forEach((food)=> { %>
                    <li><%= food.name %></li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p><%= user.username %> pantry is empty!</p>
            <% } %>
</body>

</html>